# Dependencies
node_modules/

# Next.js
.next/
out/

# Environment variables — never commit real keys
.env*.local
.env
.env.toongine

# Agent proposals — operational data, not code
requests/pending/*
requests/approved/*
requests/rejected/*
!requests/README.md
!requests/pending/EXAMPLE.md

# Build outputs
dist/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp

# Claude Code local settings
.claude/settings.local.json
.claude/mcps/
.vercel

# Hermes runtime clone (aux-tools sidecar) — large, fetched via npm run hermes:setup
hermes/vendor/

# Code-review-graph build artifacts (large — generated)
.code-review-graph/
graphify-out/

# TOON build artifacts (generated by toongine — track agents + reports, ignore cache)
# Tracked: agents/**, graphify/GRAPH_REPORT.*, codegraph/CODEGRAPH_REPORT.*, docs/**
# Ignored: cache, tmp, graph, memory, hermes, compiled dictionaries
.toon/cache/
.toon/tmp/
.toon/graph/
.toon/memory/
.toon/hermes/
.toon/dictionary.toon
.toon/*/.gitkeep
.toon/.graphify_analysis.json
.toongine.json
toongine.config.json

# Benchmarks (require toongine)
bench-*.js
