# Dependencies
node_modules/

# Next.js
.next/
out/

# Environment variables — never commit real keys
.env*.local
.env

# Agent proposals — operational data, not code
requests/pending/*
requests/approved/*
requests/rejected/*
!requests/README.md
!requests/pending/EXAMPLE.md

# Build outputs
dist/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp

# Claude Code local settings
.claude/settings.local.json
.claude/mcps/
.vercel

# Hermes runtime clone (aux-tools sidecar) — large, fetched via npm run hermes:setup
hermes/vendor/

# TOON — track source of truth, ignore build artifacts
.toon/*
# Re-include agent source files (source of truth)
!.toon/dictionary.toon
!.toon/schemas.toon
!.toon/memory/
.toon/memory/*
!.toon/memory/agent-department/
# Re-include graph reports (human-readable)
!.toon/graphs/
.toon/graphs/*
!.toon/graphs/*.md
# Everything else under .toon is a build artifact
