# Dependencies
node_modules/

# Next.js
.next/
out/

# Environment variables — never commit real keys
.env*.local
.env
.env.toongine

# Agent proposals — operational data, not code
requests/pending/*
requests/approved/*
requests/rejected/*
!requests/README.md
!requests/pending/EXAMPLE.md

# Build outputs
dist/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp

# Claude Code local settings
.claude/settings.local.json
.claude/mcps/
.vercel

# Hermes runtime clone (aux-tools sidecar) — large, fetched via npm run hermes:setup
hermes/vendor/

# Code-review-graph build artifacts (large — generated, track HTML report)
.code-review-graph/*
!.code-review-graph/graph.html
!.code-review-graph/wiki/
graphify-out/

# TOON build artifacts (generated by toongine)
# Tracked: agents/**, graphify/**, codegraph/**, code-review-graph/**, project/**, hermes/**, dictionary.toon
# Ignored: cache, tmp, binary DBs, gitkeep stubs
.toon/cache/
.toon/tmp/
.toon/**/*.db
.toon/**/*.db-*
.toon/*/.gitkeep
.toon/.graphify_analysis.json
.toon/v3/
.toongine.json
toongine.config.json

# Benchmarks (require toongine)
bench-*.js
