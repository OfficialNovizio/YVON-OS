M|Laye|tx|}
M|Laye|tx|if (!existsSync(workingDirectory)) {
M|Laye|thro|${workingDirectory}`);
M|Laye|tx|}
M|Laye|tx|if (!statSync(workingDirectory).isDirectory()) {
M|Laye|thro|${workingDirectory}`);
M|Laye|tx|}
M|Laye|tx|// ... proceed
M|Laye|tx|}
