M|Impl|`mid|
M|Impl|tx|```ts
M|Impl|tx|import { NextRequest, NextResponse } from 'nx/server'
M|Impl|cons|Record<string, { limit: number; window: number }> = {
M|Impl|'/ap|{ limit: 20, window: 60 },
M|Impl|'/ap|{ limit: 20, window: 60 },
M|Impl|'/ap|{ limit: 60, window: 60 },
M|Impl|tx|}
M|Impl|tx|// Sliding window using Edge runtime — in-memory per Edge instance
M|Impl|tx|// Resets on cold start (acceptable — degrades gracefully, doesn't block)
M|Impl|cons|number; resetAt: number }>()
M|Impl|expo|NextRequest) {
M|Impl|tx|const pathname = req.nextUrl.pathname
M|Impl|tx|const config = Object.entries(RATE_LIMITS).find(([rt]) => pathname.startsWith(rt))
M|Impl|tx|if (!config) return NextResponse.nx()
M|Impl|cons|windowSec }] = config
M|Impl|tx|const ip = req.ip ?? req.headers.get('x-forwarded-for') ?? 'unknown'
M|Impl|cons|${pathname}`
M|Impl|tx|const now = Date.now()
M|Impl|tx|const entry = requestCounts.get(key)
M|Impl|tx|if (!entry \|\| now > entry.resetAt) {
M|Impl|requ|1, resetAt: now + windowSec * 1000 })
M|Impl|tx|return NextResponse.nx()
M|Impl|tx|}
M|Impl|tx|if (entry.count >= limit) {
M|Impl|tx|return NextResponse.json(
M|Impl|er|'Rate limit exceeded. Please wait before retrying.' },
M|Impl|{ st|429, headers: { 'Retry-After': String(windowSec) } }
M|Impl|tx|)
M|Impl|tx|}
M|Impl|tx|entry.count++
M|Impl|tx|return NextResponse.nx()
M|Impl|tx|}
M|Impl|tx|export const config = {
