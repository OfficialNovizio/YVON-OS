M|SSE |Ever|
M|SSE |tx|```tsx
M|SSE |tx|const [cn, setContent] = useState('')
M|SSE |tx|const [isStreaming, setIsStreaming] = useState(false)
M|SSE |tx|async fn startStream() {
M|SSE |tx|setIsStreaming(true)
M|SSE |tx|setContent('')
M|SSE |tx|const res = await fetch('/ap/claude', {
M|SSE |meth|'POST',
M|SSE |body|JSON.stringify({ message, ventureId })
M|SSE |tx|})
M|SSE |tx|const reader = res.body!.getReader()
M|SSE |tx|const decoder = new TextDecoder()
M|SSE |tx|while (true) {
M|SSE |tx|const { done, value } = await reader.read()
M|SSE |tx|if (done) break
M|SSE |tx|const chunk = decoder.decode(value)
M|SSE |tx|const lines = chunk.split('\n')
M|SSE |tx|for (const line of lines) {
M|SSE |if (|')) {
M|SSE |tx|const data = line.slice(6)
M|SSE |tx|if (data === '[DONE]') { setIsStreaming(false); break }
M|SSE |tx|if (data === '[er]') { /* handle er */ break }
M|SSE |tx|try {
M|SSE |tx|setContent(prev => prev + data)
M|SSE |tx|} catch { /* malformed chunk — skip */ }
M|SSE |tx|}
M|SSE |tx|}
M|SSE |tx|}
M|SSE |tx|}
M|SSE |tx|```
M|SSE |tx|Always check `data !== '[DONE]'` before processing. Always handle `[er]`. Never `JSON.parse` w/o try/catch.
