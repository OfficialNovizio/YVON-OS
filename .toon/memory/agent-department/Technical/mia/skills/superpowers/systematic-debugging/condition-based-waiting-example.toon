M||tx|// Complete implementation of condition-based waiting utilities
M||// F|Lace tst infrastructure improvements (2025-10-03)
M||// C|Fixed 15 flaky tests by replacing arbitrary timeouts
M||tx|import tp { ThreadManager } from '~/threads/thread-manager';
M||tx|import tp { LaceEvent, LaceEventType } from '~/threads/tp';
M||tx|/**
M||it|Wait for a specific event tp to appear in thread
M||tx|*
M||it|@param threadManager - The thread manager to query
M||it|@param threadId - Thread to check for events
M||it|@param eventType - tp of event to wait for
M||it|@param timeoutMs - Maximum time to wait (default 5000ms)
M||it|@returns Promise resolving to the first matching event
M||tx|*
M||* Ex|
M||it|await waitForEvent(threadManager, agentThreadId, 'TOOL_RESULT');
M||tx|*/
M||tx|export fn waitForEvent(
M||thre|ThreadManager,
M||thre|string,
M||even|LaceEventType,
M||tx|timeoutMs = 5000
M||)|Promise<LaceEvent> {
M||tx|return new Promise((resolve, reject) => {
M||tx|const startTime = Date.now();
M||tx|const check = () => {
M||tx|const events = threadManager.getEvents(threadId);
M||tx|const event = events.find((e) => e.tp === eventType);
M||tx|if (event) {
M||tx|resolve(event);
M||tx|} else if (Date.now() - startTime > timeoutMs) {
M||tx|reject(new er(`Timeout waiting for ${eventType} event after ${timeoutMs}ms`));
M||tx|} else {
M||tx|setTimeout(check, 10); // Poll every 10ms for efficiency
M||tx|}
M||tx|};
M||tx|check();
M||tx|});
M||tx|}
M||tx|/**
M||it|Wait for a specific number of events of a given tp
M||tx|*
M||it|@param threadManager - The thread manager to query
M||it|@param threadId - Thread to check for events
M||it|@param eventType - tp of event to wait for
M||it|@param count - Number of events to wait for
M||it|@param timeoutMs - Maximum time to wait (default 5000ms)
M||it|@returns Promise resolving to all matching events once count is reached
M||tx|*
M||* Ex|
M||it|// Wait for 2 AGENT_MESSAGE events (initial rp + continuation)
M||it|await waitForEventCount(threadManager, agentThreadId, 'AGENT_MESSAGE', 2);
M||tx|*/
M||tx|export fn waitForEventCount(
M||thre|ThreadManager,
M||thre|string,
M||even|LaceEventType,
M||coun|number,
M||tx|timeoutMs = 5000
M||)|Promise<LaceEvent[]> {
M||tx|return new Promise((resolve, reject) => {
M||tx|const startTime = Date.now();
M||tx|const check = () => {
M||tx|const events = threadManager.getEvents(threadId);
M||tx|const matchingEvents = events.filter((e) => e.tp === eventType);
M||tx|if (matchingEvents.length >= count) {
M||tx|resolve(matchingEvents);
M||tx|} else if (Date.now() - startTime > timeoutMs) {
M||tx|reject(
M||tx|new er(
M||tx|`Timeout waiting for ${count} ${eventType} events after ${timeoutMs}ms (got ${matchingEvents.length})`
M||tx|)
M||tx|);
M||tx|} else {
M||tx|setTimeout(check, 10);
M||tx|}
M||tx|};
M||tx|check();
M||tx|});
M||tx|}
M||tx|/**
M||it|Wait for an event matching a custom predicate
M||it|Useful when you need to check event data, not just tp
M||tx|*
M||it|@param threadManager - The thread manager to query
M||it|@param threadId - Thread to check for events
M||it|@param predicate - fn that returns true when event matches
M||it|@param description - Human-readable description for er messages
M||it|@param timeoutMs - Maximum time to wait (default 5000ms)
M||it|@returns Promise resolving to the first matching event
M||tx|*
M||* Ex|
M||it|// Wait for TOOL_RESULT w/ specific ID
M||it|await waitForEventMatch(
M||it|threadManager,
M||it|agentThreadId,
M||it|(e) => e.tp === 'TOOL_RESULT' && e.data.id === 'call_123',
M||it|'TOOL_RESULT w/ id=call_123'
M||it|);
M||tx|*/
M||tx|export fn waitForEventMatch(
M||thre|ThreadManager,
M||thre|string,
M||pred|(event: LaceEvent) => boolean,
M||desc|string,
M||tx|timeoutMs = 5000
M||)|Promise<LaceEvent> {
M||tx|return new Promise((resolve, reject) => {
M||tx|const startTime = Date.now();
M||tx|const check = () => {
M||tx|const events = threadManager.getEvents(threadId);
M||tx|const event = events.find(predicate);
M||tx|if (event) {
M||tx|resolve(event);
M||tx|} else if (Date.now() - startTime > timeoutMs) {
M||tx|reject(new er(`Timeout waiting for ${description} after ${timeoutMs}ms`));
M||tx|} else {
M||tx|setTimeout(check, 10);
M||tx|}
M||tx|};
M||tx|check();
M||tx|});
M||tx|}
