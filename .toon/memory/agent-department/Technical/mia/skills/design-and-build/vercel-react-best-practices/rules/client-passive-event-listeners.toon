M|Use |cons|TouchEvent) => console.log(e.touches[0].clientX)
M|Use |cons|WheelEvent) => console.log(e.deltaY)
M|Use |tx|document.addEventListener('touchstart', handleTouch)
M|Use |tx|document.addEventListener('wheel', handleWheel)
M|Use |tx|return () => {
M|Use |tx|document.removeEventListener('touchstart', handleTouch)
M|Use |tx|document.removeEventListener('wheel', handleWheel)
M|Use |tx|}
M|Use |tx|}, [])
M|Use |tx|```
