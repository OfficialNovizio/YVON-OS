#MEM id=rules source=/root/yvon/agent-department/Technical/mia/skills/design-and-build/vercel-react-best-practices/rules/client-event-listeners.md
M|rules|title: Deduplicate Global Event Listeners
M|rules|impact: LOW
M|rules|impactDescription: single listener for N components
M|rules|tags: client, swr, event-listeners, subscription
M|rules|Use `useSWRSubscription()` to share global event listeners across component instances.
M|rules|**Incorrect (N instances = N listeners):**
M|rules|```tsx
M|rules|function useKeyboardShortcut(key: string, callback: () => void) {
M|rules|useEffect(() => {
M|rules|const handler = (e: KeyboardEvent) => {
M|rules|if (e.metaKey && e.key === key) {
M|rules|callback()
M|rules|}
M|rules|}
M|rules|window.addEventListener('keydown', handler)
M|rules|return () => window.removeEventListener('keydown', handler)
M|rules|}, [key, callback])
M|rules|}
M|rules|```
M|rules|When using the `useKeyboardShortcut` hook multiple times, each instance will register a new listener.
M|rules|**Correct (N instances = 1 listener):**
M|rules|```tsx
M|rules|import useSWRSubscription from 'swr/subscription'
M|rules|// Module-level Map to track callbacks per key
M|rules|const keyCallbacks = new Map<string, Set<() => void>>()
M|rules|function useKeyboardShortcut(key: string, callback: () => void) {
M|rules|// Register this callback in the Map
M|rules|useEffect(() => {
M|rules|if (!keyCallbacks.has(key)) {
M|rules|keyCallbacks.set(key, new Set())
M|rules|}
M|rules|keyCallbacks.get(key)!.add(callback)
M|rules|return () => {
M|rules|const set = keyCallbacks.get(key)
M|rules|if (set) {
M|rules|set.delete(callback)
M|rules|if (set.size === 0) {
M|rules|keyCallbacks.delete(key)
M|rules|}
M|rules|}
M|rules|}
M|rules|}, [key, callback])
M|rules|useSWRSubscription('global-keydown', () => {
M|rules|const handler = (e: KeyboardEvent) => {
M|rules|if (e.metaKey && keyCallbacks.has(e.key)) {
M|rules|keyCallbacks.get(e.key)!.forEach(cb => cb())
M|rules|}
M|rules|}
M|rules|window.addEventListener('keydown', handler)
M|rules|return () => window.removeEventListener('keydown', handler)
M|rules|})
M|rules|}
M|rules|function Profile() {
M|rules|// Multiple shortcuts will share the same listener
M|rules|useKeyboardShortcut('p', () => { /* ... */ })
M|rules|useKeyboardShortcut('k', () => { /* ... */ })
M|rules|// ...
M|rules|}
M|rules|```