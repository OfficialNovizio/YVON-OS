M|7.11|r.su|[]
M|7.11|tx|)
M|7.11|tx|// Parse and filter valid numbers
M|7.11|tx|// Before
M|7.11|tx|const numbers = strings
M|7.11|tx|.map(s => parseInt(s, 10))
M|7.11|tx|.filter(n => !isNaN(n))
