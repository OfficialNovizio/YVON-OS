M|5.15|tx|if (node) {
M|5.15|tx|node.style.transform = `translateX(${e.clientX}px)`
M|5.15|tx|}
M|5.15|tx|}
M|5.15|tx|window.addEventListener('mousemove', onMove)
M|5.15|tx|return () => window.removeEventListener('mousemove', onMove)
M|5.15|tx|}, [])
M|5.15|tx|return (
M|5.15|tx|<div
M|5.15|tx|ref={dotRef}
M|5.15|tx|style={{
M|5.15|posi|'fixed',
M|5.15|top|0,
M|5.15|left|0,
M|5.15|widt|8,
M|5.15|heig|8,
M|5.15|back|'black',
