M|vercel-react-best-practices|// Fetch and apply critical stylesheet immediately
M|vercel-react-best-practices|preinit('/styles/critical.css', { as: 'style' })
M|vercel-react-best-practices|return (
M|vercel-react-best-practices|<html>
