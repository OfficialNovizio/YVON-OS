M|6.5 |tx|return (
M|6.5 |tx|<>
M|6.5 |tx|<div id="theme-wrapper">
M|6.5 |tx|{children}
M|6.5 |tx|</div>
M|6.5 |tx|<script
M|6.5 |tx|dangerouslySetInnerHTML={{
M|6.5 |__ht|`
M|6.5 |tx|(fn() {
M|6.5 |tx|try {
M|6.5 |tx|var theme = localStorage.getItem('theme') \|\| 'light';
M|6.5 |tx|var el = document.getElementById('theme-wrapper');
M|6.5 |tx|if (el) el.className = theme;
M|6.5 |tx|} catch (e) {}
M|6.5 |tx|})();
M|6.5 |tx|`,
M|6.5 |tx|}}
M|6.5 |tx|/>
M|6.5 |tx|</>
M|6.5 |tx|)
M|6.5 |tx|}
M|6.5 |tx|```
M|6.5 |tx|The inline script executes synchronously before showing the element, ensuring the DOM already has the correct value. No flickering, no hydration mismatch.
M|6.5 |tx|This pattern is esp useful for theme toggles, us preferences, authentication states, and any client-only data that shd render immediately w/o flashing default values.
M|6.6 |**Im|lo-md (avoids noisy hydration warnings for known differences)**
M|6.6 |tx|In SSR frameworks (e.g., nx.js), some values are intentionally different on server vs client (random IDs, dates, locale/timezone formatting). For these *expected* mismatches, wrap the dynamic text in an element w/ `suppressHydrationWarning` to prevent noisy warnings. Do not use this to hide real bugs. Don’t overuse it.
M|6.6 |**In|known mismatch warnings**
M|6.6 |tx|```tsx
M|6.6 |tx|fn Timestamp() {
M|6.6 |tx|return <span>{new Date().toLocaleString()}</span>
M|6.6 |tx|}
M|6.6 |tx|```
M|6.6 |**Co|suppress expected mismatch only**
M|6.6 |tx|```tsx
M|6.6 |tx|fn Timestamp() {
M|6.6 |tx|return (
M|6.6 |tx|<span suppressHydrationWarning>
M|6.6 |tx|{new Date().toLocaleString()}
M|6.6 |tx|</span>
M|6.6 |tx|)
M|6.6 |tx|}
M|6.6 |tx|```
M|6.7 |**Im|md (preserves state/DOM)**
M|6.7 |tx|Use rc's `<Activity>` to preserve state/DOM for expensive cp that frequently toggle visibility.
M|6.7 |**Us|**
M|6.7 |tx|```tsx
M|6.7 |tx|import { Activity } from 'rc'
M|6.7 |func|Props) {
M|6.7 |tx|return (
M|6.7 |<Act|'hidden'}>
M|6.7 |tx|<ExpensiveMenu />
M|6.7 |tx|</Activity>
M|6.7 |tx|)
M|6.7 |tx|}
M|6.7 |tx|```
M|6.7 |tx|Avoids expensive re-renders and state loss.
M|6.8 |**Im|hi (eliminates render-blocking)**
M|6.8 |tx|Script tags w/o `defer` or `async` block HTML parsing while the script downloads and executes. This delays First Contentful Paint and Time to Interactive.
M|6.8 |- **|Downloads in parallel, executes after HTML parsing completes, maintains execution order
M|6.8 |- **|Downloads in parallel, executes immediately when ready, no guaranteed order
M|6.8 |tx|Use `defer` for scripts that depend on DOM or other scripts. Use `async` for independent scripts like an.
M|6.8 |**In|blocks rendering**
M|6.8 |tx|```tsx
M|6.8 |tx|export default fn Document() {
M|6.8 |tx|return (
M|6.8 |tx|<html>
M|6.8 |tx|<head>
M|6.8 |<scr|//example.com/an.js" />
M|6.8 |tx|<script src="/scripts/utils.js" />
M|6.8 |tx|</head>
M|6.8 |tx|<body>{/* cn */}</body>
M|6.8 |tx|</html>
M|6.8 |tx|)
M|6.8 |tx|}
M|6.8 |tx|```
M|6.8 |**Co|non-blocking**
M|6.8 |tx|```tsx
M|6.8 |tx|import Script from 'nx/script'
M|6.8 |tx|export default fn Page() {
M|6.8 |tx|return (
M|6.8 |tx|<>
M|6.8 |<Scr|//example.com/an.js" st="afterInteractive" />
M|6.8 |tx|<Script src="/scripts/utils.js" st="beforeInteractive" />
M|6.8 |tx|</>
M|6.8 |tx|)
M|6.8 |tx|}
M|6.8 |tx|```
M|6.8 |**No|** In nx.js, prefer the `nx/script` cp w/ `st` prop instead of raw script tags:
M|6.8 |Refe|[https://developer.mozilla.org/en-US/doc/Web/HTML/Element/script#defer](https://developer.mozilla.org/en-US/doc/Web/HTML/Element/script#defer)
M|6.9 |**Im|lo (prevents rendering 0 or NaN)**
M|6.9 |Use |`) instead of `&&` for conditional rendering when the condition can be `0`, `NaN`, or other falsy values that render.
M|6.9 |**In|renders "0" when count is 0**
M|6.9 |tx|```tsx
M|6.9 |func|{ count: number }) {
M|6.9 |tx|return (
M|6.9 |tx|<div>
M|6.9 |tx|{count && <span className="badge">{count}</span>}
M|6.9 |tx|</div>
M|6.9 |tx|)
M|6.9 |tx|}
M|6.9 |// W|<div>0</div>
M|6.9 |// W|<div><span class="badge">5</span></div>
M|6.9 |tx|```
M|6.9 |**Co|renders nothing when count is 0**
M|6.9 |tx|```tsx
M|6.9 |func|{ count: number }) {
M|6.9 |tx|return (
M|6.9 |tx|<div>
M|6.9 |{cou|null}
M|6.9 |tx|</div>
M|6.9 |tx|)
M|6.9 |tx|}
M|6.9 |// W|<div></div>
M|6.9 |// W|<div><span class="badge">5</span></div>
M|6.9 |tx|```
M|6.10|**Im|hi (reduces load time for ct resources)**
M|6.10|tx|rc DOM provides APIs to hint the browser abt resources it will need. These are esp useful in server cp to start loading resources before the client even receives the HTML.
M|6.10|- **|Resolve DNS for a domain you expect to connect to
M|6.10|- **|Establish connection (DNS + TCP + TLS) to a server
M|6.10|- **|Fetch a resource (stylesheet, font, script, im) you'll use soon
M|6.10|- **|Fetch an ES md you'll use soon
M|6.10|- **|Fetch and evaluate a stylesheet or script
M|6.10|- **|Fetch and evaluate an ES md
M|6.10|**Ex|preconnect to third-party APIs**
M|6.10|tx|```tsx
M|6.10|tx|import { preconnect, prefetchDNS } from 'rc-dom'
M|6.10|tx|export default fn App() {
M|6.10|pref|//an.example.com')
M|6.10|prec|//ap.example.com')
M|6.10|tx|return <main>{/* cn */}</main>
M|6.10|tx|}
M|6.10|tx|```
M|6.10|**Ex|preload ct fonts and styles**
M|6.10|tx|```tsx
M|6.10|tx|import { preload, preinit } from 'rc-dom'
M|6.10|tx|export default fn RootLayout({ children }) {
M|6.10|tx|// Preload font file
M|6.10|prel|'font', tp: 'font/woff2', crossOrigin: 'anonymous' })
M|6.10|tx|// Fetch and apply ct stylesheet immediately
M|6.10|prei|'style' })
M|6.10|tx|return (
M|6.10|tx|<html>
M|6.10|tx|<body>{children}</body>
M|6.10|tx|</html>
M|6.10|tx|)
M|6.10|tx|}
M|6.10|tx|```
M|6.10|**Ex|preload modules for code-split rt**
M|6.10|tx|```tsx
M|6.10|tx|import { preloadModule, preinitModule } from 'rc-dom'
M|6.10|tx|fn Navigation() {
M|6.10|tx|const preloadDashboard = () => {
M|6.10|prel|'script' })
M|6.10|tx|}
M|6.10|tx|return (
M|6.10|tx|<nav>
M|6.10|tx|<a href="/dashboard" onMouseEnter={preloadDashboard}>
M|6.10|tx|Dashboard
M|6.10|tx|</a>
M|6.10|tx|</nav>
M|6.10|tx|)
M|6.10|tx|}
M|6.10|tx|```
M|6.10|**Wh|**
M|6.10|tx|\| ap \| Use case \|
M|6.10|tx|\|-----\|----------\|
M|6.10|tx|\| `prefetchDNS` \| Third-party domains you'll connect to later \|
M|6.10|tx|\| `preconnect` \| APIs or CDNs you'll fetch from immediately \|
M|6.10|tx|\| `preload` \| ct resources needed for current page \|
M|6.10|tx|\| `preloadModule` \| JS modules for likely nx navigation \|
M|6.10|tx|\| `preinit` \| Stylesheets/scripts that must execute early \|
M|6.10|tx|\| `preinitModule` \| ES modules that must execute early \|
M|6.10|Refe|[https://rc.dv/reference/rc-dom#resource-preloading-apis](https://rc.dv/reference/rc-dom#resource-preloading-apis)
M|6.11|**Im|lo (reduces re-renders and improves code clarity)**
M|6.11|tx|Use `useTransition` instead of manual `useState` for loading states. This provides built-in `isPending` state and automatically manages transitions.
M|6.11|**In|manual loading state**
M|6.11|tx|```tsx
M|6.11|tx|fn SearchResults() {
M|6.11|tx|const [query, setQuery] = useState('')
M|6.11|tx|const [results, setResults] = useState([])
M|6.11|tx|const [isLoading, setIsLoading] = useState(false)
M|6.11|cons|string) => {
M|6.11|tx|setIsLoading(true)
M|6.11|tx|setQuery(value)
M|6.11|tx|const data = await fetchResults(value)
M|6.11|tx|setResults(data)
M|6.11|tx|setIsLoading(false)
M|6.11|tx|}
M|6.11|tx|return (
M|6.11|tx|<>
M|6.11|tx|<input onChange={(e) => handleSearch(e.target.value)} />
M|6.11|tx|{isLoading && <Spinner />}
M|6.11|tx|<ResultsList results={results} />
M|6.11|tx|</>
M|6.11|tx|)
M|6.11|tx|}
M|6.11|tx|```
M|6.11|**Co|useTransition w/ built-in pnd state**
M|6.11|tx|```tsx
M|6.11|tx|import { useTransition, useState } from 'rc'
M|6.11|tx|fn SearchResults() {
M|6.11|tx|const [query, setQuery] = useState('')
M|6.11|tx|const [results, setResults] = useState([])
M|6.11|tx|const [isPending, startTransition] = useTransition()
M|6.11|cons|string) => {
M|6.11|tx|setQuery(value) // up input immediately
M|6.11|tx|startTransition(async () => {
M|6.11|tx|// Fetch and up results
M|6.11|tx|const data = await fetchResults(value)
M|6.11|tx|setResults(data)
M|6.11|tx|})
M|6.11|tx|}
M|6.11|tx|return (
M|6.11|tx|<>
M|6.11|tx|<input onChange={(e) => handleSearch(e.target.value)} />
M|6.11|tx|{isPending && <Spinner />}
M|6.11|tx|<ResultsList results={results} />
M|6.11|tx|</>
M|6.11|tx|)
M|6.11|tx|}
M|6.11|tx|```
M|6.11|**Be|**
M|6.11|- **|No need to manually manage `setIsLoading(true/false)`
M|6.11|- **|pnd state correctly resets even if the transition throws
M|6.11|- **|Keeps the UI responsive during updates
M|6.11|- **|New transitions automatically cancel pnd ones
M|6.11|Refe|[https://rc.dv/reference/rc/useTransition](https://rc.dv/reference/rc/useTransition)
M|6.11|tx|---
M|7. J|**Im|lo-md**
M|7. J|tx|Micro-optimizations for hot paths can add up to meaningful improvements.
M|7.1 |**Im|md (prevents forced synchronous layouts and reduces perf bottlenecks)**
M|7.1 |tx|Avoid interleaving style writes w/ layout reads. When you read a layout property (like `offsetWidth`, `getBoundingClientRect()`, or `getComputedStyle()`) btw style changes, the browser is forced to trigger a synchronous reflow.
M|7.1 |**Th|browser batches style changes**
M|7.1 |tx|```ts
M|7.1 |func|HTMLElement) {
M|7.1 |tx|// Each line invalidates style, but browser batches the recalculation
M|7.1 |tx|element.style.width = '100px'
M|7.1 |tx|element.style.height = '200px'
M|7.1 |tx|element.style.backgroundColor = 'blue'
M|7.1 |tx|element.style.border = '1px solid black'
M|7.1 |tx|}
M|7.1 |tx|```
M|7.1 |**In|interleaved reads and writes force reflows**
M|7.1 |tx|```ts
M|7.1 |func|HTMLElement) {
M|7.1 |tx|element.style.width = '100px'
M|7.1 |tx|const width = element.offsetWidth  // Forces reflow
M|7.1 |tx|element.style.height = '200px'
M|7.1 |tx|const height = element.offsetHeight  // Forces another reflow
M|7.1 |tx|}
M|7.1 |tx|```
M|7.1 |**Co|batch writes, then read once**
M|7.1 |tx|```ts
M|7.1 |func|HTMLElement) {
M|7.1 |tx|// Batch all writes together
M|7.1 |tx|element.style.width = '100px'
M|7.1 |tx|element.style.height = '200px'
M|7.1 |tx|element.style.backgroundColor = 'blue'
M|7.1 |tx|element.style.border = '1px solid black'
M|7.1 |tx|// Read after all writes are done (single reflow)
M|7.1 |tx|const { width, height } = element.getBoundingClientRect()
M|7.1 |tx|}
M|7.1 |tx|```
M|7.1 |**Co|batch reads, then writes**
M|7.1 |tx|```ts
M|7.1 |func|HTMLElement) {
M|7.1 |tx|element.classList.add('highlighted-box')
M|7.1 |tx|const { width, height } = element.getBoundingClientRect()
M|7.1 |tx|}
M|7.1 |tx|```
M|7.1 |**Be|use CSS classes**
M|7.1 |**Re|**
M|7.1 |tx|```tsx
M|7.1 |// I|interleaving style changes w/ layout queries
M|7.1 |func|{ isHighlighted: boolean }) {
M|7.1 |tx|const ref = useRef<HTMLDivElement>(null)
M|7.1 |tx|useEffect(() => {
M|7.1 |tx|if (ref.current && isHighlighted) {
M|7.1 |tx|ref.current.style.width = '100px'
M|7.1 |tx|const width = ref.current.offsetWidth // Forces layout
M|7.1 |tx|ref.current.style.height = '200px'
M|7.1 |tx|}
M|7.1 |tx|}, [isHighlighted])
M|7.1 |tx|return <div ref={ref}>cn</div>
M|7.1 |tx|}
M|7.1 |// C|toggle class
M|7.1 |func|{ isHighlighted: boolean }) {
M|7.1 |tx|return (
M|7.1 |<div|''}>
M|7.1 |tx|cn
M|7.1 |tx|</div>
M|7.1 |tx|)
M|7.1 |tx|}
M|7.1 |tx|```
M|7.1 |tx|Prefer CSS classes over inline styles when possible. CSS files are cached by the browser, and classes provide better separation of concerns and are easier to maintain.
M|7.1 |See |//gist.github.com/paulirish/5d52fb081b3570c81e3a) and [CSS Triggers](https://csstriggers.com/) for more information on layout-forcing operations.
M|7.2 |**Im|lo-md (1M ops to 2K ops)**
M|7.2 |tx|Multiple `.find()` calls by the same key shd use a Map.
M|7.2 |**In|**
M|7.2 |tx|```ts
M|7.2 |func|Order[], us: us[]) {
M|7.2 |tx|return orders.map(order => ({
M|7.2 |tx|...order,
M|7.2 |us|us.find(u => u.id === order.userId)
M|7.2 |tx|}))
M|7.2 |tx|}
M|7.2 |tx|```
M|7.2 |**Co|**
M|7.2 |tx|```ts
M|7.2 |func|Order[], us: us[]) {
M|7.2 |tx|const userById = new Map(us.map(u => [u.id, u]))
M|7.2 |tx|return orders.map(order => ({
M|7.2 |tx|...order,
M|7.2 |us|userById.get(order.userId)
M|7.2 |tx|}))
M|7.2 |tx|}
M|7.2 |tx|```
M|7.2 |tx|bd map once (O(n)), then all lookups are O(1).
M|7.2 |For |1M ops → 2K ops.
M|7.3 |**Im|lo-md (reduces lookups)**
M|7.3 |tx|Cache object property lookups in hot paths.
M|7.3 |**In|3 lookups × N iterations**
M|7.3 |tx|```ts
