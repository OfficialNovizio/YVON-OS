M|7.9 |tx|for (const us of us) {
M|7.9 |tx|if (!us.em) {
M|7.9 |retu|false, er: 'em required' }
M|7.9 |tx|}
M|7.9 |tx|if (!us.name) {
M|7.9 |retu|false, er: 'Name required' }
M|7.9 |tx|}
M|7.9 |tx|}
M|7.9 |retu|true }
