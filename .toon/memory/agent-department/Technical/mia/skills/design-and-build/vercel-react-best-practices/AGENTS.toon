M|7.4 |tx|}
M|7.4 |tx|```
M|7.4 |**Co|cached results**
M|7.4 |tx|```ts
M|7.4 |tx|// md-level cache
M|7.4 |tx|const slugifyCache = new Map<string, string>()
M|7.4 |func|string): string {
M|7.4 |tx|if (slugifyCache.has(text)) {
M|7.4 |tx|return slugifyCache.get(text)!
M|7.4 |tx|}
M|7.4 |tx|const result = slugify(text)
M|7.4 |tx|slugifyCache.set(text, result)
M|7.4 |tx|return result
M|7.4 |tx|}
M|7.4 |func|{ projects: Project[] }) {
M|7.4 |tx|return (
M|7.4 |tx|<div>
M|7.4 |tx|{projects.map(project => {
M|7.4 |tx|// Computed only once per unique project name
M|7.4 |tx|const slug = cachedSlugify(project.name)
M|7.4 |tx|return <ProjectCard key={project.id} slug={slug} />
M|7.4 |tx|})}
M|7.4 |tx|</div>
M|7.4 |tx|)
M|7.4 |tx|}
M|7.4 |tx|```
M|7.4 |**Si|**
M|7.4 |tx|```ts
M|7.4 |let |boolean \| null = null
M|7.4 |func|boolean {
M|7.4 |tx|if (isLoggedInCache !== null) {
M|7.4 |tx|return isLoggedInCache
M|7.4 |tx|}
M|7.4 |tx|isLoggedInCache = document.cookie.includes('auth=')
M|7.4 |tx|return isLoggedInCache
