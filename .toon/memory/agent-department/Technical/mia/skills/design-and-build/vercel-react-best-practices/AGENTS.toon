M|vercel-react-best-practices|```typescript
M|vercel-react-best-practices|'use server'
M|vercel-react-best-practices|import { verifySession } from '@/lib/auth'
M|vercel-react-best-practices|import { z } from 'zod'
M|vercel-react-best-practices|const updateProfileSchema = z.object({
M|vercel-react-best-practices|userId: z.string().uuid(),
M|vercel-react-best-practices|name: z.string().min(1).max(100),
M|vercel-react-best-practices|email: z.string().email()
M|vercel-react-best-practices|})
