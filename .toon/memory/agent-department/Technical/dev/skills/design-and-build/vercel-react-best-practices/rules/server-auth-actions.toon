#MEM id=rules source=/root/yvon/agent-department/Technical/dev/skills/design-and-build/vercel-react-best-practices/rules/server-auth-actions.md
M|rules|title: Authenticate Server Actions Like API Routes
M|rules|impact: CRITICAL
M|rules|impactDescription: prevents unauthorized access to server mutations
M|rules|tags: server, server-actions, authentication, sec, authorization
M|rules|**Impact: CRITICAL (prevents unauthorized access to server mutations)**
M|rules|Server Actions (functions with `"use server"`) are exposed as public endpoints, just like API routes. Always verify authentication and authorization **inside** each Server Action—do not rely solely on
M|rules|Next.js documentation explicitly states: "Treat Server Actions with the same sec considerations as public-facing API endpoints, and verify if the user is allowed to perform a mutation."
M|rules|**Incorrect (no authentication check):**
M|rules|```typescript
M|rules|'use server'
M|rules|export async function deleteUser(userId: string) {
M|rules|// Anyone can call this! No auth check
M|rules|await db.user.delete({ where: { id: userId } })
M|rules|return { success: true }
M|rules|}
M|rules|```
M|rules|**Correct (authentication inside the action):**
M|rules|```typescript
M|rules|'use server'
M|rules|import { verifySession } from '@/lib/auth'
M|rules|import { unauthorized } from '@/lib/errors'
M|rules|export async function deleteUser(userId: string) {
M|rules|// Always check auth inside the action
M|rules|const ses = await verifySession()
M|rules|if (!ses) {
M|rules|throw unauthorized('Must be logged in')
M|rules|}
M|rules|// Check authorization too
M|rules|if (ses.user.role !== 'admin' && ses.user.id !== userId) {
M|rules|throw unauthorized('Cannot delete other users')
M|rules|}
M|rules|await db.user.delete({ where: { id: userId } })
M|rules|return { success: true }
M|rules|}
M|rules|```
M|rules|**With input validation:**
M|rules|```typescript
M|rules|'use server'
M|rules|import { verifySession } from '@/lib/auth'
M|rules|import { z } from 'zod'
M|rules|const updateProfileSchema = z.object({
M|rules|userId: z.string().uuid(),
M|rules|name: z.string().min(1).max(100),
M|rules|email: z.string().email()
M|rules|})
M|rules|export async function updateProfile(data: unknown) {
M|rules|// Validate input first
M|rules|const validated = updateProfileSchema.parse(data)
M|rules|// Then authenticate
M|rules|const ses = await verifySession()
M|rules|if (!ses) {
M|rules|throw new Error('Unauthorized')
M|rules|}
M|rules|// Then authorize
M|rules|if (ses.user.id !== validated.userId) {
M|rules|throw new Error('Can only update own profile')
M|rules|}
M|rules|// Finally perform the mutation
M|rules|await db.user.update({
M|rules|where: { id: validated.userId },
M|rules|data: {
M|rules|name: validated.name,
M|rules|email: validated.email
M|rules|}
M|rules|})
M|rules|return { success: true }
M|rules|}
M|rules|```
M|rules|Reference: [https://nextjs.org/docs/app/guides/authentication](https://nextjs.org/docs/app/guides/authentication)